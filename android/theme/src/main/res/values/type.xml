<?xml version="1.0" encoding="utf-8"?>
<!--
  Neon Grid type scale. Two voices:
    • DISPLAY voice  — wide, letter-spaced, techy (display / headline / title / label).
    • MONO voice     — terminal-style body text.
  Defaults use system families so the theme builds and looks strong everywhere; see the README
  to upgrade the display voice to Orbitron and the mono voice to Share Tech Mono via Downloadable
  Fonts for the exact reference look.
-->
<resources>

    <!-- ===== Display ===== -->
    <style name="TextAppearance.NeonGrid.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">@color/ng_text</item>
    </style>
    <style name="TextAppearance.NeonGrid.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textColor">@color/ng_text</item>
    </style>
    <style name="TextAppearance.NeonGrid.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textColor">@color/ng_text</item>
    </style>

    <!-- ===== Headline ===== -->
    <style name="TextAppearance.NeonGrid.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textColor">@color/ng_text</item>
    </style>
    <style name="TextAppearance.NeonGrid.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textColor">@color/ng_text</item>
    </style>
    <style name="TextAppearance.NeonGrid.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textColor">@color/ng_text</item>
    </style>

    <!-- ===== Title ===== -->
    <style name="TextAppearance.NeonGrid.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/ng_text</item>
    </style>
    <style name="TextAppearance.NeonGrid.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/ng_text</item>
    </style>
    <style name="TextAppearance.NeonGrid.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textColor">@color/ng_text_secondary</item>
    </style>

    <!-- ===== Body (mono voice) ===== -->
    <style name="TextAppearance.NeonGrid.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/ng_text</item>
    </style>
    <style name="TextAppearance.NeonGrid.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/ng_text_secondary</item>
    </style>
    <style name="TextAppearance.NeonGrid.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/ng_text_dim</item>
    </style>

    <!-- ===== Label (uppercase, spaced — buttons, tabs, overlines) ===== -->
    <style name="TextAppearance.NeonGrid.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <style name="TextAppearance.NeonGrid.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.14</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <style name="TextAppearance.NeonGrid.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.16</item>
        <item name="android:textColor">@color/ng_text_dim</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Overline: the tiny uppercase eyebrow used above values/labels in the reference. -->
    <style name="TextAppearance.NeonGrid.Overline" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.2</item>
        <item name="android:textColor">@color/ng_text_dim</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Hex/value readout — glowing mono accent (e.g. tag IDs). -->
    <style name="TextAppearance.NeonGrid.Mono.Accent" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textColor">@color/ng_cyan</item>
        <item name="android:shadowColor">@color/ng_cyan</item>
        <item name="android:shadowRadius">9</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
    </style>

</resources>
