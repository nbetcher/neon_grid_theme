<?xml version="1.0" encoding="utf-8"?>
<!--
  Neon Grid — the theme. Dark Material 3 lit by the full source spectrum.
  Role map:  primary=fuchsia · secondary=green · tertiary=orange · error=red
             (cyan/blue/violet/yellow are used directly by styles & drawables for info,
              metrics, brand gradients and caution — see styles.xml / drawables).
-->
<resources>

    <style name="Theme.NeonGrid" parent="Theme.Material3.Dark.NoActionBar">

        <!-- ===== Color roles ===== -->
        <item name="colorPrimary">@color/ng_fuchsia</item>
        <item name="colorOnPrimary">@color/ng_on_neon</item>
        <item name="colorPrimaryContainer">@color/ng_surface_higher</item>
        <item name="colorOnPrimaryContainer">@color/ng_fuchsia</item>
        <item name="colorPrimaryInverse">@color/ng_fuchsia</item>

        <item name="colorSecondary">@color/ng_green</item>
        <item name="colorOnSecondary">@color/ng_on_neon</item>
        <item name="colorSecondaryContainer">@color/ng_surface_high</item>
        <item name="colorOnSecondaryContainer">@color/ng_green</item>

        <item name="colorTertiary">@color/ng_orange</item>
        <item name="colorOnTertiary">@color/ng_on_neon</item>
        <item name="colorTertiaryContainer">@color/ng_surface_high</item>
        <item name="colorOnTertiaryContainer">@color/ng_orange</item>

        <item name="colorError">@color/ng_red</item>
        <item name="colorOnError">@color/ng_on_neon</item>
        <item name="colorErrorContainer">@color/ng_surface_high</item>
        <item name="colorOnErrorContainer">@color/ng_red</item>

        <!-- ===== Surfaces / background ===== -->
        <item name="android:colorBackground">@color/ng_void</item>
        <item name="colorOnBackground">@color/ng_text</item>
        <item name="colorSurface">@color/ng_surface</item>
        <item name="colorOnSurface">@color/ng_text</item>
        <item name="colorSurfaceVariant">@color/ng_surface_high</item>
        <item name="colorOnSurfaceVariant">@color/ng_text_secondary</item>
        <item name="colorSurfaceInverse">@color/ng_text</item>
        <item name="colorOnSurfaceInverse">@color/ng_void</item>
        <item name="colorSurfaceContainerLowest">@color/ng_void</item>
        <item name="colorSurfaceContainerLow">@color/ng_abyss</item>
        <item name="colorSurfaceContainer">@color/ng_surface</item>
        <item name="colorSurfaceContainerHigh">@color/ng_surface_high</item>
        <item name="colorSurfaceContainerHighest">@color/ng_surface_higher</item>
        <item name="colorSurfaceBright">@color/ng_surface_higher</item>
        <item name="colorSurfaceDim">@color/ng_void</item>
        <item name="colorOutline">@color/ng_outline</item>
        <item name="colorOutlineVariant">@color/ng_border</item>

        <!-- Keep our exact surface tones (no elevation tinting). -->
        <item name="elevationOverlayEnabled">false</item>

        <!-- Legacy control colors -->
        <item name="colorControlActivated">@color/ng_fuchsia</item>
        <item name="colorControlNormal">@color/ng_text_dim</item>
        <item name="colorControlHighlight">@color/ng_ripple_light</item>
        <item name="android:textColorPrimary">@color/ng_text</item>
        <item name="android:textColorSecondary">@color/ng_text_secondary</item>
        <item name="android:textColorHint">@color/ng_text_dim</item>

        <!-- ===== Typography ===== -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.NeonGrid.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.NeonGrid.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.NeonGrid.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.NeonGrid.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.NeonGrid.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.NeonGrid.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.NeonGrid.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.NeonGrid.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.NeonGrid.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.NeonGrid.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.NeonGrid.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.NeonGrid.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.NeonGrid.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.NeonGrid.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.NeonGrid.LabelSmall</item>
        <item name="android:fontFamily">monospace</item>
        <item name="fontFamily">monospace</item>

        <!-- ===== Shapes ===== -->
        <item name="shapeAppearanceCornerExtraSmall">@style/ShapeAppearance.NeonGrid.ExtraSmall</item>
        <item name="shapeAppearanceCornerSmall">@style/ShapeAppearance.NeonGrid.Small</item>
        <item name="shapeAppearanceCornerMedium">@style/ShapeAppearance.NeonGrid.Medium</item>
        <item name="shapeAppearanceCornerLarge">@style/ShapeAppearance.NeonGrid.Large</item>
        <item name="shapeAppearanceCornerExtraLarge">@style/ShapeAppearance.NeonGrid.ExtraLarge</item>

        <!-- ===== Window / system bars ===== -->
        <item name="android:windowBackground">@drawable/ng_window_background</item>
        <item name="android:statusBarColor">@color/ng_abyss</item>
        <item name="android:navigationBarColor">@color/ng_abyss</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- ===== Default widget styles — theme everything we can ===== -->
        <item name="materialButtonStyle">@style/Widget.NeonGrid.Button</item>
        <item name="borderlessButtonStyle">@style/Widget.NeonGrid.Button.Text</item>
        <item name="floatingActionButtonStyle">@style/Widget.NeonGrid.FloatingActionButton</item>
        <item name="extendedFloatingActionButtonStyle">@style/Widget.NeonGrid.ExtendedFloatingActionButton</item>
        <item name="materialCardViewStyle">@style/Widget.NeonGrid.CardView</item>
        <item name="textInputStyle">@style/Widget.NeonGrid.TextInputLayout</item>
        <item name="editTextStyle">@style/Widget.NeonGrid.EditText</item>
        <item name="materialSwitchStyle">@style/Widget.NeonGrid.Switch</item>
        <item name="checkboxStyle">@style/Widget.NeonGrid.CheckBox</item>
        <item name="radioButtonStyle">@style/Widget.NeonGrid.RadioButton</item>
        <item name="sliderStyle">@style/Widget.NeonGrid.Slider</item>
        <item name="chipStyle">@style/Widget.NeonGrid.Chip</item>
        <item name="appBarLayoutStyle">@style/Widget.NeonGrid.AppBarLayout</item>
        <item name="toolbarStyle">@style/Widget.NeonGrid.Toolbar</item>
        <item name="bottomNavigationStyle">@style/Widget.NeonGrid.BottomNavigation</item>
        <item name="navigationRailStyle">@style/Widget.NeonGrid.NavigationRail</item>
        <item name="navigationViewStyle">@style/Widget.NeonGrid.NavigationView</item>
        <item name="tabStyle">@style/Widget.NeonGrid.TabLayout</item>
        <item name="snackbarStyle">@style/Widget.NeonGrid.Snackbar</item>
        <item name="snackbarTextViewStyle">@style/Widget.NeonGrid.Snackbar.TextView</item>
        <item name="snackbarButtonStyle">@style/Widget.NeonGrid.Snackbar.Button</item>
        <item name="circularProgressIndicatorStyle">@style/Widget.NeonGrid.CircularProgress</item>
        <item name="linearProgressIndicatorStyle">@style/Widget.NeonGrid.LinearProgress</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.NeonGrid.MaterialAlertDialog</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.NeonGrid.BottomSheetDialog</item>
        <item name="badgeStyle">@style/Widget.NeonGrid.Badge</item>
        <item name="materialDividerStyle">@style/Widget.NeonGrid.Divider</item>
    </style>

    <!-- Flat-background variant (no radial glow) for embedded surfaces. -->
    <style name="Theme.NeonGrid.Solid">
        <item name="android:windowBackground">@color/ng_void</item>
    </style>

    <!-- Edge-to-edge variant: transparent system bars. -->
    <style name="Theme.NeonGrid.EdgeToEdge">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

</resources>
