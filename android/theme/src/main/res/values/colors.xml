    <color name="ng_orange_28">#47FF8A00</color>
    <color name="ng_orange_70">#B3FF8A00</color>

    <color name="ng_cyan_10">#1A00D4FF</color>
    <color name="ng_cyan_18">#2E00D4FF</color>
    <color name="ng_cyan_25">#4000D4FF</color>
    <color name="ng_cyan_28">#4700D4FF</color>

    <color name="ng_blue_18">#2E0088FF</color>
    <color name="ng_blue_28">#470088FF</color>

    <color name="ng_violet_18">#2E7B2FFF</color>
