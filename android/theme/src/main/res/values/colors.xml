<?xml version="1.0" encoding="utf-8"?>
<!--
  Neon Grid — palette. Inspired by a certain 80's film with "The Grid": a deep blue-black substrate lit by neon.
  The named trio (fuchsia / green / orange) carries the identity; cyan/violet/red support it.
  All hex is #AARRGGBB. Translucent "_NN" tokens are the on-dark fills for neon controls.

  Refreshed to the brighter source spectrum (Chromium ARM32 Tracker refresh): the neon is pushed
  hotter — cyan #00E0FF, green #00FF95, orange #FF9500, blue #1F9BFF, violet #8A45FF, red #FF3B5C,
  yellow #FFE11A — over slightly warmer text on the same deep substrate.
-->
<resources>

    <!-- ============ Substrate (deep blue-black) ============ -->
    <color name="ng_void">#FF0A0A12</color>
    <color name="ng_abyss">#FF0D0D1A</color>
    <color name="ng_surface">#FF111125</color>
    <color name="ng_surface_high">#FF161638</color>
    <color name="ng_surface_higher">#FF1C1C44</color>
    <color name="ng_input">#FF0E0E20</color>
    <color name="ng_border">#FF20204A</color>
    <color name="ng_outline">#FF2C2C5E</color>

    <!-- ============ The neon trio ============ -->
    <color name="ng_fuchsia">#FFFF2DAA</color>
    <color name="ng_green">#FF00FF95</color>
    <color name="ng_orange">#FFFF9500</color>

    <!-- ============ The rest of the spectrum (the full source palette, all first-class) ============ -->
    <color name="ng_cyan">#FF00E0FF</color>
    <color name="ng_blue">#FF1F9BFF</color>
    <color name="ng_violet">#FF8A45FF</color>
    <color name="ng_red">#FFFF3B5C</color>
    <color name="ng_yellow">#FFFFE11A</color>

    <!-- On a SOLID neon fill, content must be the dark substrate for contrast. -->
    <color name="ng_on_neon">#FF07070E</color>

    <!-- ============ Text ============ -->
    <color name="ng_text">#FFEAF0FB</color>
    <color name="ng_text_secondary">#FF9FB0D6</color>
    <color name="ng_text_dim">#FF62749C</color>
    <color name="ng_text_disabled">#FF3C486A</color>

    <!-- ============ Translucent neon fills (neon-on-dark controls) ============ -->
