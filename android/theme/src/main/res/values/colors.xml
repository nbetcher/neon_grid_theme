<?xml version="1.0" encoding="utf-8"?>
<!--
  Neon Grid — palette. Inspired by a certain 80's film with "The Grid": a deep blue-black substrate lit by neon.
  The named trio (fuchsia / green / orange) carries the identity; cyan/violet/red support it.
  All hex is #AARRGGBB. Translucent "_NN" tokens are the on-dark fills for neon controls.
-->
<resources>

    <!-- ============ Substrate (deep blue-black) ============ -->
    <color name="ng_void">#FF0A0A12</color>
    <color name="ng_abyss">#FF0D0D1A</color>
    <color name="ng_surface">#FF121226</color>
    <color name="ng_surface_high">#FF171738</color>
    <color name="ng_surface_higher">#FF1C1C44</color>
    <color name="ng_input">#FF0E0E20</color>
    <color name="ng_border">#FF1E1E46</color>
    <color name="ng_outline">#FF2C2C5E</color>

    <!-- ============ The neon trio ============ -->
    <color name="ng_fuchsia">#FFFF2DAA</color>
    <color name="ng_green">#FF00FF88</color>
    <color name="ng_orange">#FFFF8A00</color>

    <!-- ============ The rest of the spectrum (the full source palette, all first-class) ============ -->
    <color name="ng_cyan">#FF00D4FF</color>
    <color name="ng_blue">#FF0088FF</color>
    <color name="ng_violet">#FF7B2FFF</color>
    <color name="ng_red">#FFFF3355</color>
    <color name="ng_yellow">#FFFFDD00</color>

    <!-- On a SOLID neon fill, content must be the dark substrate for contrast. -->
    <color name="ng_on_neon">#FF07070E</color>

    <!-- ============ Text ============ -->
    <color name="ng_text">#FFE6ECF5</color>
    <color name="ng_text_secondary">#FF93A4C4</color>
    <color name="ng_text_dim">#FF5C6E92</color>
    <color name="ng_text_disabled">#FF3C486A</color>

    <!-- ============ Translucent neon fills (neon-on-dark controls) ============ -->
    <color name="ng_fuchsia_10">#1AFF2DAA</color>
    <color name="ng_fuchsia_18">#2EFF2DAA</color>
    <color name="ng_fuchsia_28">#47FF2DAA</color>
    <color name="ng_fuchsia_45">#73FF2DAA</color>
    <color name="ng_fuchsia_70">#B3FF2DAA</color>

    <color name="ng_green_10">#1A00FF88</color>
    <color name="ng_green_18">#2E00FF88</color>
    <color name="ng_green_28">#4700FF88</color>
    <color name="ng_green_70">#B300FF88</color>

    <color name="ng_orange_10">#1AFF8A00</color>
