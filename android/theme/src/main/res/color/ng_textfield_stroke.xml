<?xml version="1.0" encoding="utf-8"?>
<!-- Outlined text-field box stroke: lights primary on focus, dimmer primary on hover. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:color="@color/ng_border" />
    <item android:state_focused="true" android:color="?attr/colorPrimary" />
    <item android:state_hovered="true" android:alpha="0.70" android:color="?attr/colorPrimary" />
    <item android:color="@color/ng_outline" />
</selector>
