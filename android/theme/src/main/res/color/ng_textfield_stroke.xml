<?xml version="1.0" encoding="utf-8"?>
<!-- Outlined text-field box stroke: lights fuchsia on focus. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:color="@color/ng_border" />
    <item android:state_focused="true" android:color="@color/ng_fuchsia" />
    <item android:state_hovered="true" android:color="@color/ng_fuchsia_70" />
    <item android:color="@color/ng_border" />
</selector>
