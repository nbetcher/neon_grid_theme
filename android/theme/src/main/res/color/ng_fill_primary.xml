<?xml version="1.0" encoding="utf-8"?>
<!-- Translucent neon fill derived from the theme's primary color. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:color="@color/ng_transparent" />
    <item android:state_pressed="true" android:alpha="0.30" android:color="?attr/colorPrimary" />
    <item android:state_hovered="true" android:alpha="0.30" android:color="?attr/colorPrimary" />
    <item android:state_focused="true" android:alpha="0.30" android:color="?attr/colorPrimary" />
    <item android:alpha="0.18" android:color="?attr/colorPrimary" />
</selector>
