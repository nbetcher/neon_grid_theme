<?xml version="1.0" encoding="utf-8"?>
<!-- Segmented (toggle-group) child fill: translucent primary when checked. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:alpha="0.20" android:color="?attr/colorPrimary" />
    <item android:color="@color/ng_transparent" />
</selector>
