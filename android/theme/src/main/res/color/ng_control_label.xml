<?xml version="1.0" encoding="utf-8"?>
<!-- Switch / checkbox / radio label: lights to the primary accent when the control is active,
     normal text otherwise (mirrors how chips & tabs emphasise the selected state). -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:color="@color/ng_text_disabled" />
    <item android:state_checked="true" android:color="?attr/colorPrimary" />
    <item android:color="@color/ng_text" />
</selector>
