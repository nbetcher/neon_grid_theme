<?xml version="1.0" encoding="utf-8"?>
<!-- Unselected radio: dim neon ring. A 38dp transparent sizer keeps the same footprint as
     ng_radio_on so the ring doesn't shift when selected. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/ng_transparent" />
            <size android:width="38dp" android:height="38dp" />
        </shape>
    </item>
    <item
        android:width="22dp"
        android:height="22dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="@color/ng_input" />
            <stroke android:width="2dp" android:color="@color/ng_outline" />
        </shape>
    </item>
</layer-list>
