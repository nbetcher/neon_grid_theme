<?xml version="1.0" encoding="utf-8"?>
<!-- Clean, fully anti-aliased Spinner box (rounded rect + vector caret) — replaces the platform's
     jagged underline + bitmap caret. Secondary stroke + secondary caret. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/ng_input" />
            <stroke android:width="1dp" android:color="@color/ng_stroke_secondary" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item
        android:width="20dp"
        android:height="20dp"
        android:end="10dp"
        android:gravity="end|center_vertical"
        android:drawable="@drawable/ng_ic_chevron_down" />
</layer-list>
