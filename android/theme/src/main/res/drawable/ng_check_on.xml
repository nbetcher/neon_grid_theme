<?xml version="1.0" encoding="utf-8"?>
<!-- Checked box: soft neon glow halo (baked) behind a translucent primary fill + glowing primary
     stroke + primary check. The 38dp footprint matches ng_check_off so the box doesn't shift. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:drawable="@drawable/ng_glow_cb"
        android:gravity="center" />
    <item
        android:width="22dp"
        android:height="22dp"
        android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="@color/ng_fill_primary" />
            <stroke android:width="2dp" android:color="?attr/colorPrimary" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item
        android:drawable="@drawable/ng_ic_check"
        android:gravity="center" />
</layer-list>
