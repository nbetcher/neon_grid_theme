<?xml version="1.0" encoding="utf-8"?>
<!-- Signature panel hairline: transparent -> neon -> transparent. Place 2dp tall atop a card. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="@color/ng_transparent"
        android:centerColor="@color/ng_fuchsia"
        android:endColor="@color/ng_transparent" />
    <size android:height="2dp" />
</shape>
