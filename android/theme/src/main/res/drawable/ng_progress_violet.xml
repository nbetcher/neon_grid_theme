<?xml version="1.0" encoding="utf-8"?>
<!-- Tron progress: dark bordered channel (track) + glowing violet fill (clipped). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background" android:drawable="@drawable/ng_bar_track" />
    <item android:id="@android:id/progress">
        <clip
            android:clipOrientation="horizontal"
            android:drawable="@drawable/ng_bar_fill_violet"
            android:gravity="start" />
    </item>
</layer-list>
