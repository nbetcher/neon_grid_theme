<?xml version="1.0" encoding="utf-8"?>
<!-- Tri-neon hairline for hero panels / dialog tops: fuchsia -> green -> orange. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="@color/ng_fuchsia"
        android:centerColor="@color/ng_green"
        android:endColor="@color/ng_orange" />
    <size android:height="2dp" />
</shape>
