<?xml version="1.0" encoding="utf-8"?>
<!-- Hero/dialog top accent: cyan -> violet -> fuchsia, the source's signature sweep. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="@color/ng_cyan"
        android:centerColor="@color/ng_violet"
        android:endColor="@color/ng_fuchsia" />
    <size android:height="2dp" />
</shape>
