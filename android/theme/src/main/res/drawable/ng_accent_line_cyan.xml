<?xml version="1.0" encoding="utf-8"?>
<!-- The source's default panel hairline: transparent -> cyan -> transparent. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="@color/ng_transparent"
        android:centerColor="@color/ng_cyan"
        android:endColor="@color/ng_transparent" />
    <size android:height="2dp" />
</shape>
