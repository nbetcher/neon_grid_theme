<?xml version="1.0" encoding="utf-8"?>
<!--
  Accordion caret — a clean stroked chevron pointing DOWN (expanded). Tinted to text-dim so it
  reads as quiet chrome. Rotate the host ImageView (-90° collapsed → 0° expanded) to animate, and
  swap the tint to ?attr/colorPrimary when the row is open for the lit-caret look.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="@color/ng_text_dim">
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@android:color/white"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M6,9.5 L12,15.5 L18,9.5" />
</vector>
