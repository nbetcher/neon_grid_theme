<?xml version="1.0" encoding="utf-8"?>
<!-- Accordion body background: just a 1dp faint-cyan rule pinned to the top edge, spanning the full
     width (the source's header→body `border-top`). The card already supplies the surface fill, so
     everything below the rule is transparent. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="top" android:height="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/ng_cyan_12" />
        </shape>
    </item>
</layer-list>
